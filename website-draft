<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>adpt — verified developer identity</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@300;400;500&display=swap');

:root {
  --bg:       #08090a;
  --bg-1:     #0e0f11;
  --bg-2:     #141518;
  --bg-3:     #1c1d21;
  --border:   rgba(255,255,255,0.07);
  --border-2: rgba(255,255,255,0.04);
  --text-1:   #f1f0ee;
  --text-2:   #8a8a8e;
  --text-3:   #4a4a50;
  --green:    #3dd68c;
  --green-bg: rgba(61,214,140,0.07);
  --green-br: rgba(61,214,140,0.2);
  --amber:    #e8a84a;
  --blue:     #4d9ef7;
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }

body {
  background: var(--bg);
  color: var(--text-1);
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  line-height: 1.5;
  overflow-x: hidden;
}

/* ── NAV ── */
header {
  position: fixed;
  inset: 0 0 auto;
  z-index: 100;
  height: 52px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
  border-bottom: 1px solid var(--border);
  background: rgba(8,9,10,0.85);
  backdrop-filter: blur(12px) saturate(1.4);
}

.logo {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 15px;
  font-weight: 600;
  letter-spacing: -0.3px;
  color: var(--text-1);
  text-decoration: none;
}

.logo-mark {
  width: 22px;
  height: 22px;
  background: var(--green);
  border-radius: 5px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 700;
  color: #08090a;
  font-style: italic;
  font-family: Georgia, serif;
  flex-shrink: 0;
}

nav {
  display: flex;
  align-items: center;
  gap: 2px;
}

nav a {
  padding: 5px 12px;
  font-size: 13px;
  font-weight: 400;
  color: var(--text-2);
  text-decoration: none;
  border-radius: 5px;
  transition: color 0.15s, background 0.15s;
}

nav a:hover { color: var(--text-1); background: rgba(255,255,255,0.05); }

.nav-sep { width: 1px; height: 16px; background: var(--border); margin: 0 8px; }

.btn-nav {
  padding: 5px 12px;
  font-size: 13px;
  font-weight: 500;
  color: var(--text-1);
  background: rgba(255,255,255,0.08);
  border: 1px solid var(--border);
  border-radius: 6px;
  text-decoration: none;
  transition: background 0.15s, border-color 0.15s;
  cursor: pointer;
}

.btn-nav:hover { background: rgba(255,255,255,0.13); border-color: rgba(255,255,255,0.15); }

.btn-nav-primary {
  background: var(--green);
  border-color: var(--green);
  color: #08090a;
  margin-left: 4px;
}

.btn-nav-primary:hover { background: #4de89e; border-color: #4de89e; color: #08090a; }

/* ── HERO ── */
.hero {
  padding: 132px 24px 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  position: relative;
  overflow: hidden;
}

/* Subtle radial glow behind hero */
.hero::before {
  content: '';
  position: absolute;
  width: 900px;
  height: 500px;
  top: 60px;
  left: 50%;
  transform: translateX(-50%);
  background: radial-gradient(ellipse, rgba(61,214,140,0.055) 0%, transparent 65%);
  pointer-events: none;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 10px 4px 6px;
  background: var(--green-bg);
  border: 1px solid var(--green-br);
  border-radius: 20px;
  font-size: 11.5px;
  font-weight: 500;
  color: var(--green);
  margin-bottom: 28px;
  letter-spacing: 0.1px;
  animation: fadeUp 0.5s ease both;
}

.hero-badge-dot {
  width: 5px; height: 5px;
  background: var(--green);
  border-radius: 50%;
  animation: pulse 2s ease infinite;
}

@keyframes pulse {
  0%,100% { opacity:1; box-shadow: 0 0 0 0 rgba(61,214,140,0.4); }
  50%      { opacity:0.7; box-shadow: 0 0 0 4px rgba(61,214,140,0); }
}

.hero h1 {
  font-size: clamp(38px, 6vw, 64px);
  font-weight: 600;
  letter-spacing: -1.5px;
  line-height: 1.08;
  max-width: 720px;
  color: var(--text-1);
  animation: fadeUp 0.5s ease 0.1s both;
}

.hero h1 .dim { color: var(--text-3); }

.hero-sub {
  margin-top: 20px;
  font-size: 16px;
  font-weight: 400;
  color: var(--text-2);
  max-width: 480px;
  line-height: 1.6;
  animation: fadeUp 0.5s ease 0.2s both;
}

.hero-actions {
  margin-top: 32px;
  display: flex;
  gap: 10px;
  align-items: center;
  animation: fadeUp 0.5s ease 0.3s both;
}

.btn-primary {
  padding: 8px 16px;
  font-size: 13.5px;
  font-weight: 500;
  background: var(--green);
  color: #08090a;
  border: none;
  border-radius: 7px;
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 6px;
  transition: background 0.15s;
  cursor: pointer;
}

.btn-primary:hover { background: #4de89e; }

.btn-secondary {
  padding: 8px 16px;
  font-size: 13.5px;
  font-weight: 400;
  background: transparent;
  color: var(--text-2);
  border: 1px solid var(--border);
  border-radius: 7px;
  text-decoration: none;
  transition: color 0.15s, border-color 0.15s, background 0.15s;
}

.btn-secondary:hover { color: var(--text-1); border-color: rgba(255,255,255,0.15); background: rgba(255,255,255,0.04); }

/* ── HERO PROFILE UI ── */
.hero-ui {
  margin-top: 56px;
  width: 100%;
  max-width: 860px;
  position: relative;
  animation: fadeUp 0.6s ease 0.4s both;
}

/* Top gradient fade */
.hero-ui::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 120px;
  background: linear-gradient(to bottom, transparent, var(--bg));
  pointer-events: none;
}

.ui-window {
  background: var(--bg-1);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
  box-shadow:
    0 0 0 1px rgba(0,0,0,0.5),
    0 32px 64px rgba(0,0,0,0.5),
    0 4px 16px rgba(0,0,0,0.3);
}

.ui-titlebar {
  height: 40px;
  background: var(--bg-2);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  padding: 0 16px;
  gap: 12px;
}

.ui-dots { display: flex; gap: 6px; }
.ui-dot { width:11px;height:11px;border-radius:50%; }
.ui-dot:nth-child(1){background:#ff5f56}
.ui-dot:nth-child(2){background:#ffbd2e}
.ui-dot:nth-child(3){background:#27c93f}

.ui-url {
  flex: 1;
  background: var(--bg-3);
  border-radius: 5px;
  height: 24px;
  display: flex;
  align-items: center;
  padding: 0 10px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--text-3);
  gap: 6px;
}

.ui-url .url-green { color: var(--green); }

.ui-body {
  display: grid;
  grid-template-columns: 220px 1fr;
  height: 380px;
}

/* SIDEBAR */
.ui-sidebar {
  border-right: 1px solid var(--border);
  padding: 16px 0;
  background: var(--bg-2);
  overflow: hidden;
}

.sidebar-section {
  padding: 0 12px 8px;
}

.sidebar-label {
  font-size: 10.5px;
  font-weight: 500;
  color: var(--text-3);
  padding: 4px 8px;
  letter-spacing: 0.3px;
  margin-bottom: 2px;
}

.sidebar-item {
  display: flex;
  align-items: center;
  gap: 7px;
  padding: 5px 8px;
  border-radius: 5px;
  font-size: 12.5px;
  color: var(--text-2);
  cursor: default;
  transition: background 0.1s;
}

.sidebar-item:hover { background: rgba(255,255,255,0.05); }

.sidebar-item.active {
  background: rgba(61,214,140,0.1);
  color: var(--text-1);
}

.s-icon {
  width: 16px; height: 16px;
  border-radius: 3px;
  display: flex; align-items: center; justify-content: center;
  font-size: 9px;
  flex-shrink: 0;
  opacity: 0.7;
}

.sidebar-divider { height: 1px; background: var(--border); margin: 6px 12px; }

.sidebar-stat {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 4px 8px;
  font-size: 11px;
  border-radius: 4px;
}

.sidebar-stat .sk { color: var(--text-3); }
.sidebar-stat .sv { color: var(--text-2); font-family: 'JetBrains Mono', monospace; font-size: 10.5px; }
.sidebar-stat .sv.g { color: var(--green); }

/* MAIN PANEL */
.ui-main {
  padding: 20px 24px;
  overflow: hidden;
  position: relative;
}

.profile-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--border-2);
}

.profile-identity {
  display: flex;
  align-items: center;
  gap: 12px;
}

.profile-avatar {
  width: 38px; height: 38px;
  background: linear-gradient(135deg, #1f3a2e, #2a5c42);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 15px;
  font-weight: 600;
  color: var(--green);
  border: 1px solid var(--border);
  flex-shrink: 0;
}

.profile-name {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-1);
  letter-spacing: -0.2px;
}

.profile-handle {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--text-3);
  margin-top: 2px;
}

.profile-badges {
  display: flex;
  gap: 6px;
  align-items: center;
}

.badge {
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.1px;
}

.badge-green { background: var(--green-bg); color: var(--green); border: 1px solid var(--green-br); }
.badge-dim   { background: rgba(255,255,255,0.05); color: var(--text-3); border: 1px solid var(--border-2); }

.profile-narrative {
  font-size: 13px;
  color: var(--text-2);
  line-height: 1.65;
  margin-bottom: 18px;
  font-style: italic;
}

/* METRICS ROW */
.metrics {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  margin-bottom: 18px;
}

.metric {
  background: var(--bg-3);
  border: 1px solid var(--border-2);
  border-radius: 7px;
  padding: 10px 12px;
}

.metric-val {
  font-family: 'JetBrains Mono', monospace;
  font-size: 17px;
  font-weight: 500;
  color: var(--text-1);
  line-height: 1;
  margin-bottom: 3px;
}

.metric-val.g { color: var(--green); }

.metric-key {
  font-size: 10.5px;
  color: var(--text-3);
  letter-spacing: 0.2px;
}

/* ACTIVITY */
.activity-label {
  font-size: 11px;
  font-weight: 500;
  color: var(--text-3);
  margin-bottom: 8px;
  letter-spacing: 0.3px;
}

.activity-grid {
  display: flex;
  gap: 2px;
  flex-wrap: wrap;
}

.activity-cell {
  width: 10px; height: 10px;
  border-radius: 2px;
  background: var(--bg-3);
  border: 1px solid var(--border-2);
}

.activity-cell.l1 { background: rgba(61,214,140,0.15); border-color: rgba(61,214,140,0.15); }
.activity-cell.l2 { background: rgba(61,214,140,0.35); border-color: rgba(61,214,140,0.3); }
.activity-cell.l3 { background: rgba(61,214,140,0.6);  border-color: rgba(61,214,140,0.5); }
.activity-cell.l4 { background: var(--green);           border-color: var(--green); }

/* STACK PILLS */
.stack-row {
  display: flex;
  gap: 5px;
  flex-wrap: wrap;
  margin-top: 14px;
}

.stack-pill {
  padding: 3px 9px;
  border-radius: 4px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  font-weight: 400;
  background: var(--bg-3);
  color: var(--text-2);
  border: 1px solid var(--border-2);
}

.stack-pill.hi {
  background: var(--green-bg);
  color: var(--green);
  border-color: var(--green-br);
}

/* SIGNAL BAR at the bottom of window */
.ui-statusbar {
  height: 28px;
  border-top: 1px solid var(--border);
  display: flex;
  align-items: center;
  padding: 0 16px;
  gap: 16px;
  background: var(--bg-2);
}

.status-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  color: var(--text-3);
}

.status-dot { width:5px;height:5px;border-radius:50%; }
.status-dot.green { background:var(--green); box-shadow:0 0 4px var(--green); }
.status-dot.amber { background:var(--amber); }

/* ── SECTIONS ── */
.section { padding: 100px 24px; max-width: 1080px; margin: 0 auto; }

.section-eyebrow {
  font-size: 11.5px;
  font-weight: 500;
  color: var(--green);
  letter-spacing: 0.3px;
  margin-bottom: 12px;
}

.section h2 {
  font-size: clamp(28px, 3.5vw, 42px);
  font-weight: 600;
  letter-spacing: -0.8px;
  line-height: 1.12;
  color: var(--text-1);
  margin-bottom: 16px;
}

.section h2 .dim { color: var(--text-3); }

.section-desc {
  font-size: 15px;
  color: var(--text-2);
  max-width: 480px;
  line-height: 1.65;
  margin-bottom: 52px;
}

/* HOW */
.steps {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  border-radius: 10px;
  overflow: hidden;
}

.step {
  background: var(--bg-1);
  padding: 28px;
  transition: background 0.15s;
}

.step:hover { background: var(--bg-2); }

.step-num {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--text-3);
  margin-bottom: 20px;
}

.step h3 {
  font-size: 14.5px;
  font-weight: 600;
  color: var(--text-1);
  margin-bottom: 8px;
  letter-spacing: -0.2px;
}

.step p {
  font-size: 13.5px;
  color: var(--text-2);
  line-height: 1.6;
}

/* SIGNAL GRID */
.signal-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  border-radius: 10px;
  overflow: hidden;
}

.signal-card {
  background: var(--bg-1);
  padding: 28px;
  transition: background 0.15s;
  position: relative;
}

.signal-card:hover { background: var(--bg-2); }

.sc-eyebrow {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10.5px;
  color: var(--text-3);
  margin-bottom: 12px;
  letter-spacing: 0.2px;
}

.sc-eyebrow.g { color: var(--green); }

.signal-card h4 {
  font-size: 14.5px;
  font-weight: 600;
  color: var(--text-1);
  margin-bottom: 8px;
  letter-spacing: -0.2px;
}

.signal-card p {
  font-size: 13px;
  color: var(--text-2);
  line-height: 1.6;
}

/* COMPARISON */
.compare-table {
  width: 100%;
  border-collapse: collapse;
  border: 1px solid var(--border);
  border-radius: 10px;
  overflow: hidden;
}

.compare-table th {
  padding: 12px 20px;
  background: var(--bg-2);
  font-size: 11.5px;
  font-weight: 500;
  text-align: left;
  letter-spacing: 0.2px;
  border-bottom: 1px solid var(--border);
}

.compare-table th:not(:first-child) { text-align: center; }
.compare-table th.g { color: var(--green); }
.compare-table th.d { color: var(--text-3); }

.compare-table td {
  padding: 11px 20px;
  font-size: 13px;
  border-bottom: 1px solid var(--border-2);
}

.compare-table tr:last-child td { border-bottom: none; }
.compare-table td:first-child { color: var(--text-2); }
.compare-table td:not(:first-child) { text-align: center; }

.compare-table tr:hover td { background: rgba(255,255,255,0.015); }

.check { color: var(--green); font-size: 13px; }
.cross { color: var(--text-3); font-size: 13px; }
.adpt-col { background: rgba(61,214,140,0.03); }

/* PRICING */
.pricing-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}

.pricing-card {
  background: var(--bg-1);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 24px;
  transition: border-color 0.15s;
  position: relative;
}

.pricing-card:hover { border-color: rgba(255,255,255,0.14); }

.pricing-card.featured {
  border-color: var(--green-br);
  background: var(--green-bg);
}

.pricing-card.featured::before {
  content: 'Most popular';
  position: absolute;
  top: -1px; left: 50%; transform: translateX(-50%);
  background: var(--green);
  color: #08090a;
  font-size: 11px;
  font-weight: 600;
  padding: 2px 12px;
  border-radius: 0 0 6px 6px;
  letter-spacing: 0.1px;
}

.pc-tier {
  font-size: 11px;
  font-weight: 500;
  color: var(--text-3);
  margin-bottom: 16px;
  letter-spacing: 0.3px;
  text-transform: uppercase;
}

.pc-tier.g { color: var(--green); }

.pc-price {
  font-size: 36px;
  font-weight: 600;
  color: var(--text-1);
  letter-spacing: -1px;
  line-height: 1;
  margin-bottom: 4px;
}

.pc-price .cur {
  font-size: 18px;
  vertical-align: super;
  font-weight: 400;
  color: var(--text-2);
}

.pc-price.free { color: var(--green); }

.pc-period {
  font-size: 12px;
  color: var(--text-3);
  margin-bottom: 20px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--border-2);
}

.pc-desc {
  font-size: 13px;
  color: var(--text-2);
  line-height: 1.6;
  margin-bottom: 20px;
}

.pc-features {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 7px;
}

.pc-features li {
  font-size: 12.5px;
  color: var(--text-2);
  display: flex;
  gap: 8px;
  align-items: flex-start;
}

.pc-features li::before {
  content: '—';
  color: var(--text-3);
  flex-shrink: 0;
  font-size: 11px;
  margin-top: 1px;
}

/* CTA */
.cta-wrap {
  max-width: 1080px;
  margin: 0 auto;
  padding: 0 24px 100px;
}

.cta-inner {
  background: var(--bg-1);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 56px 48px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
  position: relative;
  overflow: hidden;
}

.cta-inner::before {
  content: '';
  position: absolute;
  width: 500px; height: 300px;
  background: radial-gradient(ellipse, rgba(61,214,140,0.05) 0%, transparent 70%);
  right: -100px; top: 50%; transform: translateY(-50%);
  pointer-events: none;
}

.cta-left h2 {
  font-size: 26px;
  font-weight: 600;
  letter-spacing: -0.5px;
  color: var(--text-1);
  line-height: 1.2;
  margin-bottom: 8px;
}

.cta-left p {
  font-size: 14px;
  color: var(--text-2);
  line-height: 1.5;
  max-width: 380px;
}

.cta-right {
  display: flex;
  gap: 8px;
  flex-shrink: 0;
  align-items: center;
  position: relative;
}

.cta-input {
  width: 220px;
  padding: 8px 14px;
  background: var(--bg-3);
  border: 1px solid var(--border);
  border-radius: 7px;
  color: var(--text-1);
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  outline: none;
  transition: border-color 0.15s;
}

.cta-input:focus { border-color: rgba(255,255,255,0.2); }
.cta-input::placeholder { color: var(--text-3); }

/* FOOTER */
footer {
  border-top: 1px solid var(--border);
  padding: 20px 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.footer-left {
  display: flex;
  align-items: center;
  gap: 20px;
}

.footer-logo { font-size: 13px; font-weight: 600; color: var(--text-2); }

.footer-copy { font-size: 12px; color: var(--text-3); }

.footer-links { display: flex; gap: 16px; }

.footer-links a {
