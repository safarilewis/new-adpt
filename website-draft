<script>
// Activity grid
const grid = document.getElementById('actGrid');
const levels = [0,0,0,1,1,2,2,3,4,3,2,1,1,0,1,2,3,4,3,2,1,2,3,4,4,3,2,1,0,0,1,1,2,3,4,4,3,3,2,1,0,0,1,2,3,4,3,2,1,0,0,1,2,3,3,4,3,2,1,0,0,1,1,2,3,4,4,3,2,1,0,0,1,2,3,4,3,2,1,0,0,1,2,3,4,3,2,1,0,0,1,2,3,4,3,2,1,0,0,1,2,3,4,3,2];
levels.forEach(l => {
  const c = document.createElement('div');
  c.className = 'activity-cell' + (l ? ' l'+l : '');
  grid.appendChild(c);
});

// Scroll reveal
const observer = new IntersectionObserver(
  entries => entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('in'); }),
  { threshold: 0.1 }
);
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// CTA button
document.getElementById('ctaBtn').addEventListener('click', function(e) {
  e.preventDefault();
  this.textContent = 'You\'re in ✓';
  this.style.background = '#4de89e';
});
</script>
